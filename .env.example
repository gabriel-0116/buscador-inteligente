DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Vision detector (cascade pipeline) ───────────────────────────────────────
# Provider + key are mandatory if you want vision detection.
VISION_DETECTOR_PROVIDER="openai"          # 'openai' | 'anthropic'
VISION_DETECTOR_API_KEY=""

# Cascade behavior:
#   auto   (default) — try heuristic first, only call vision when needed
#   always           — always call vision (legacy behavior; expensive)
#   off              — never call vision; heuristic only
VISION_DETECTOR_MODE="auto"

# Cheap model used by the cascade. Required when MODE != off.
# Legacy var VISION_DETECTOR_MODEL is honored as fallback for cheap model.
VISION_DETECTOR_MODEL_CHEAP="gpt-5.4-mini"

# Premium model. Only invoked when VISION_USE_PREMIUM_FALLBACK=true AND the
# cheap model returned 0 products on a page that looked productful.
VISION_DETECTOR_MODEL_PREMIUM="gpt-5.5"
VISION_USE_PREMIUM_FALLBACK="false"

# Hard cap on vision calls per catalog (per-page budget). When the budget
# hits zero, remaining pages stay on the heuristic regardless of mode.
CATALOG_MAX_VISION_PAGES="20"

# Cost knobs for the boxes-only detector. The page is downscaled to a
# cheap JPEG before being sent to the model; coordinates are scaled back
# to the original page resolution for the actual crop.
VISION_DETECTOR_MAX_IMAGE_WIDTH="1280"
VISION_DETECTOR_JPEG_QUALITY="75"
VISION_DETECTOR_MAX_OUTPUT_TOKENS="800"

# Structural detector (PyMuPDF). The primary detectors (GRID_LAYOUT, PDF_LAYOUT)
# extract the PDF's real structure via scripts/extract_pdf_layout.py. PYTHON_BIN
# selects the interpreter Node spawns; it must `import fitz` (pip install PyMuPDF).
PYTHON_BIN="python3"

# Verbose per-page detector logging for the listed page numbers (debug only).
CATALOG_DEBUG_PAGES="3,4,5,17,26,28,58,60,80,87"

# ── Page-level strategy (PAGE_LEVEL_SEARCH_REFACTOR.md) ─────────────────────
# The new pipeline analyzes each rendered page with a multimodal model and
# saves PageProductMention rows (no crops). Search returns *pages*, with the
# matched product surfaced as the reason. Set to "legacy_crops" to keep the
# old ProductCandidate crop-based pipeline.
CATALOG_PROCESSING_MODE="page_mentions"     # 'page_mentions' (default) | 'legacy_crops'
SEARCH_MODE="page_mentions"                 # 'page_mentions' (default) | 'legacy_candidates'

# Multimodal analyzer (reuses VISION_DETECTOR_PROVIDER / VISION_DETECTOR_API_KEY).
# PAGE_ANALYZER_MODEL is preferred; falls back to VISION_DETECTOR_MODEL_CHEAP.
PAGE_ANALYZER_MODEL=""                       # e.g. 'gpt-4o-mini', 'claude-haiku-4-5'
PAGE_ANALYZER_MAX_OUTPUT_TOKENS="2400"

# Image-query analyzer (the user's search image → ImageQueryProfile).
QUERY_ANALYZER_MODEL=""                      # falls back to PAGE_ANALYZER_MODEL
QUERY_ANALYZER_MAX_OUTPUT_TOKENS="1200"
QUERY_ANALYZER_MAX_IMAGE_WIDTH="1024"

# Text/semantic embeddings for PageProductMention.searchText. The Prisma
# schema column is vector(1536); changing the dimension here requires a
# matching schema/migration update.
TEXT_EMBEDDING_PROVIDER="openai"
TEXT_EMBEDDING_MODEL="text-embedding-3-small"
TEXT_EMBEDDING_DIMENSIONS="1536"
# Optional override — falls back to OPENAI_API_KEY then VISION_DETECTOR_API_KEY.
TEXT_EMBEDDING_API_KEY=""
