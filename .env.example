DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Vision detector (cascade pipeline) ───────────────────────────────────────
# Provider + key are mandatory if you want vision detection.
VISION_DETECTOR_PROVIDER="openai"          # 'openai' | 'anthropic'
VISION_DETECTOR_API_KEY=""

# Cascade behavior:
#   auto   (default) — try heuristic first, only call vision when needed
#   always           — always call vision (legacy behavior; expensive)
#   off              — never call vision; heuristic only
VISION_DETECTOR_MODE="auto"

# Cheap model used by the cascade. Required when MODE != off.
# Legacy var VISION_DETECTOR_MODEL is honored as fallback for cheap model.
VISION_DETECTOR_MODEL_CHEAP="gpt-5.4-mini"

# Premium model. Only invoked when VISION_USE_PREMIUM_FALLBACK=true AND the
# cheap model returned 0 products on a page that looked productful.
VISION_DETECTOR_MODEL_PREMIUM="gpt-5.5"
VISION_USE_PREMIUM_FALLBACK="false"

# Hard cap on vision calls per catalog (per-page budget). When the budget
# hits zero, remaining pages stay on the heuristic regardless of mode.
CATALOG_MAX_VISION_PAGES="20"
