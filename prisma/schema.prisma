generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  catalogs  Catalog[]
}

model Catalog {
  id               String        @id @default(cuid())
  supplierId       String
  fileName         String
  status           CatalogStatus @default(PROCESSING)
  pageCount        Int?
  imageCount       Int?
  candidateCount   Int?
  // Page-level strategy counter — total PageProductMention rows.
  pageProductCount Int?
  pdfStoragePath   String?
  error            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  supplier        Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  images          ProductImage[]
  pages           CatalogPage[]
  candidates      ProductCandidate[]
  analyses        PageAnalysis[]
  productMentions PageProductMention[]

  @@index([supplierId])
  @@index([status])
}

// Legacy — kept for backward compat; not used in the main search pipeline anymore
model ProductImage {
  id        String   @id @default(cuid())
  catalogId String
  imageUrl  String
  width     Int
  height    Int
  fileSize  Int?
  embedding Unsupported("vector(768)")?
  createdAt DateTime @default(now())

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
}

model CatalogPage {
  id         String   @id @default(cuid())
  catalogId  String
  pageNumber Int
  imageUrl   String
  width      Int
  height     Int
  createdAt  DateTime @default(now())

  catalog         Catalog              @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  candidates      ProductCandidate[]
  analyses        PageAnalysis[]
  productMentions PageProductMention[]

  @@index([catalogId])
  @@unique([catalogId, pageNumber])
}

model ProductCandidate {
  id          String               @id @default(cuid())
  catalogId   String
  pageId      String?
  originalUrl String
  cropUrl     String
  width       Int
  height      Int
  fileSize    Int?
  sourceType  CandidateSourceType  @default(PAGE_CROP)
  cropX       Int?
  cropY       Int?
  cropWidth   Int?
  cropHeight  Int?

  detectedLabel String?
  functionGroup String?
  confidence    Float?

  isSearchable Boolean  @default(false)
  qualityScore Float?
  rejectReason String?
  cardUrl      String?

  // Structured product metadata produced by the multimodal vision detector
  productName      String?
  productNamePt    String?
  category         String?
  model            String?
  originalText     String?
  descriptionPt    String?
  sourceDetector   String?
  visionConfidence Float?
  rawVisionJson    Json?

  embedding Unsupported("vector(768)")?
  createdAt DateTime                   @default(now())

  catalog Catalog      @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  page    CatalogPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([catalogId])
  @@index([pageId])
  @@index([functionGroup])
  @@index([sourceDetector])
}

model PageAnalysis {
  id             String   @id @default(cuid())
  catalogId      String
  pageId         String
  pageNumber     Int
  provider       String?
  model          String?
  rawJson        Json
  productsCount  Int
  error          String?
  createdAt      DateTime @default(now())

  catalog Catalog     @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  page    CatalogPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@index([pageId])
}

// Page-level search unit — see PAGE_LEVEL_SEARCH_REFACTOR.md.
// Each row represents one product detected by the multimodal analyzer on a
// catalog page. There is no crop: the page is the visual result, the
// mention is the unit of intelligence. The embedding is *textual/semantic*
// over the consolidated `searchText` — independent from the visual DINOv2
// embedding still used by the legacy ProductCandidate pipeline.
model PageProductMention {
  id        String @id @default(cuid())
  catalogId String
  pageId    String

  pageNumber Int

  namePt        String
  originalName  String?
  descriptionPt String?
  category      String?
  functionGroup String?

  colors              String[]
  visualAttributes    String[]
  technicalAttributes String[]
  notConfuseWith      String[]
  commercialUse       String?

  isKit       Boolean  @default(false)
  kitContains String[]

  confidence     Float?
  evidenceText   String?
  // "vision" | "pdf_text" | "both" | "manual"
  evidenceSource String?

  searchText String
  embedding  Unsupported("vector(1536)")?

  rawJson   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catalog Catalog     @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  page    CatalogPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@index([pageId])
  @@index([functionGroup])
  @@index([category])
  @@index([pageNumber])
}

enum CandidateSourceType {
  PAGE_CROP
  EMBEDDED_IMAGE
  MANUAL
}

enum CatalogStatus {
  PROCESSING
  READY
  FAILED
}
